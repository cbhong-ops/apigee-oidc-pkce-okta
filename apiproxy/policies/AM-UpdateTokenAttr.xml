<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage continueOnError="false" enabled="true" name="AM-UpdateTokenAttr">
  <DisplayName>AM-UpdateTokenAttr</DisplayName>
  <Properties/>
  <Remove>
    <Headers>
      <Header name="Authorization"/>
    </Headers>
    <FormParams>
      <FormParam name="scope"/>
    </FormParams>
    <Payload> </Payload>
  </Remove>
  <AssignVariable>
    <Name>expires_in_ms</Name>
    <Template>{expires_in}000</Template>
  </AssignVariable>
  <!-- set the same value in the response from Okta -->
  <AssignVariable>
    <Name>refresh_expires_in_ms</Name>
    <Value>86400000</Value>
  </AssignVariable>
  <!-- set the same value that is set in Okta -->
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
  <AssignTo createNew="false" transport="http" type="request"/>
</AssignMessage>
