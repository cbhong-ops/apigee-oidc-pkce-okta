<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="kvm">
  <Description/>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>VA-APIKEY</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="Set KVM Key">
      <Description/>
      <Request>
        <Step>
          <Name>EV-kvm-item</Name>
        </Step>
        <Step>
          <Name>KVM-put-item</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-kvm-success</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="Get KVM Key">
      <Description/>
      <Request>
        <Step>
          <Name>KVM-get-item</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-kvm-response</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/") and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="Delete KVM Key">
      <Description/>
      <Request/>
      <Response/>
      <Condition>(proxy.pathsuffix MatchesPath "/") and (request.verb = "DELETE")</Condition>
    </Flow>
    <Flow name="unknown request">
      <Description/>
      <Request>
        <Step>
          <Name>RF-UnknownRequest</Name>
        </Step>
      </Request>
      <Response/>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/v1/oidc-pkce/kvm</BasePath>
    <Properties/>
    <VirtualHost>default</VirtualHost>
  </HTTPProxyConnection>
  <RouteRule name="NoRouteRule"/>
</ProxyEndpoint>
